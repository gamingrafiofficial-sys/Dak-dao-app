{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores profile information for both regular users and helpers.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Firebase Auth ID" },
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "description": "URL to user's profile picture" },
        "role": { "type": "string", "enum": ["user", "helper", "admin"], "description": "User's role in the system" },
        "phoneNumber": { "type": "string", "description": "Contact number" },
        "isOnline": { "type": "boolean", "description": "Whether the helper is currently available" },
        "category": { "type": "string", "description": "Service category for helpers (e.g., electrician)" },
        "rating": { "type": "number", "description": "Average rating for helpers" },
        "totalEarnings": { "type": "number", "description": "Total earnings for helpers" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "address": { "type": "string" },
            "district": { "type": "string" },
            "thana": { "type": "string" }
          }
        },
        "verified": { "type": "boolean", "description": "Whether the helper is verified" },
        "verificationStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"], "description": "Current status of the helper's verification request" }
      },
      "required": ["uid", "role"]
    },
    "ServiceRequest": {
      "title": "Service Request",
      "description": "Represents a request for help from a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who requested help" },
        "helperId": { "type": "string", "description": "UID of the assigned helper (if any)" },
        "category": { "type": "string", "description": "Category of help needed" },
        "description": { "type": "string", "description": "Description of the problem" },
        "workAddress": { "type": "string", "description": "Specific address for the work" },
        "status": { "type": "string", "enum": ["pending", "assigned", "in-progress", "completed", "cancelled"], "description": "Current status of the request" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "address": { "type": "string" },
            "district": { "type": "string" },
            "thana": { "type": "string" }
          }
        },
        "estimatedCost": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "cancelledAt": { "type": "string", "format": "date-time" },
        "cancelledBy": { "type": "string", "enum": ["user", "helper"] },
        "urgent": { "type": "boolean", "description": "Whether this is an urgent request" }
      },
      "required": ["userId", "category", "status", "location", "createdAt"]
    },
    "Chat": {
      "title": "Chat Message",
      "description": "Messages between user and helper for a specific request.",
      "type": "object",
      "properties": {
        "requestId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requestId", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/requests/{requestId}": {
      "schema": "ServiceRequest",
      "description": "Service request documents."
    },
    "/requests/{requestId}/messages/{messageId}": {
      "schema": "Chat",
      "description": "Chat messages for a request."
    }
  }
}
